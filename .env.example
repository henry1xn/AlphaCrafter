# Copy to ".env" and fill in secrets. Never commit ".env".

# --- LLM ---
# Provider: anthropic | openai | minimax | stub (empty = auto-pick first with keys)
ALPHACRAFTER_LLM_PROVIDER=
ALPHACRAFTER_LLM_TEMPERATURE=0.2
ALPHACRAFTER_LLM_TIMEOUT_SEC=120
# LLM 交互日志（JSONL，每行一次调用；Miner / Screener）。0=关闭
ALPHACRAFTER_LLM_LOG=1
# 留空则写入 <ALPHACRAFTER_DATA_DIR>/logs/llm_interactions.jsonl
ALPHACRAFTER_LLM_LOG_PATH=
# 每条记录中 system/user/response 的最大字符预览（防日志过大）
ALPHACRAFTER_LLM_LOG_PREVIEW_CHARS=4000

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI-compatible (DeepSeek V3 etc.): set base + model + key
# DeepSeek example: OPENAI_BASE_URL=https://api.deepseek.com  OPENAI_MODEL=deepseek-chat
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat

# MiniMax (OpenAI-style messages on chatcompletion_v2)
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_API_URL=https://api.minimax.io/v1/text/chatcompletion_v2
# Optional: some tenants need a group id header
MINIMAX_GROUP_ID=

# Long system prompts: optional truncation (chars) for universal pack
ALPHACRAFTER_PROMPT_MAX_CHARS=
ALPHACRAFTER_PROMPT_INCLUDE_UNIVERSAL=1
ALPHACRAFTER_UNIVERSAL_PROMPT_CHARS=6000
ALPHACRAFTER_MINER_MAX_TOKENS=1400

# Optional LangChain / tracing
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false

# --- Paths ---
ALPHACRAFTER_DATA_DIR=
# Default if empty: <project>/data
ALPHACRAFTER_DB_PATH=
# Default if empty: <ALPHACRAFTER_DATA_DIR>/shared_memory.db

# --- Data pipeline ---
# Polite delay between Yahoo chart requests (seconds; ignored for local crypto k-lines)
ALPHACRAFTER_HTTP_SLEEP=0.35

# --- Local crypto k-lines (no Yahoo / no wiki universe) ---
# Absolute or relative path to a folder of per-symbol *.csv / *.parquet (e.g. BTCUSDT.csv)
ALPHACRAFTER_CRYPTO_DATA_DIR=
# Universe ranking when using crypto dir: volume | none (market cap not in OHLCV files)
ALPHACRAFTER_CRYPTO_RANK_BY=volume
ALPHACRAFTER_CRYPTO_LOOKBACK_DAYS=90
# 是否递归扫描子目录下的 k 线（Binance 常见 .../klines/BTCUSDT/*.parquet）；0=仅当前一层
ALPHACRAFTER_CRYPTO_SCAN_SUBDIRS=1
# Annualization for Sharpe / AR when asset class is crypto (default 365 if ALPHACRAFTER_ASSET_CLASS=crypto)
ALPHACRAFTER_BARS_PER_YEAR=

# --- Orchestration (optional) ---
ALPHACRAFTER_ORCH_TICKER_LIMIT=20
ALPHACRAFTER_PANEL_DAYS=200
ALPHACRAFTER_PANEL_SLEEP=0
# Paper Table 1 phases (optional): training | validation | backtesting | live_trading
ALPHACRAFTER_PAPER_SPLIT=
ALPHACRAFTER_MINER_MAX_ITERATIONS=100
# Defaults in code are slightly permissive for crypto / short panels; tighten for production research.
ALPHACRAFTER_MINER_IC_ACCEPT=0.02
ALPHACRAFTER_MINER_IC_RETAIN=0.008
# After Miner, if Z is empty, try built-ins with IC >= accept * ratio (code default 0.38)
ALPHACRAFTER_MINER_SEED_IC_RATIO=0.38
# Set to 1 to never insert built-in factors when Z is empty
ALPHACRAFTER_DISABLE_BUILTIN_SEED=0
ALPHACRAFTER_MINER_MAX_Z=16
ALPHACRAFTER_SCREENER_MIN_FACTORS=1
ALPHACRAFTER_SCREENER_TOP_K=10
ALPHACRAFTER_TRADER_MAX_EXPLORATIONS=12
ALPHACRAFTER_TRADER_STALL=4
